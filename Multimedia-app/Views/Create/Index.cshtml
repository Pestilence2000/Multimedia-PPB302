@model Multimedia_app.Models.Artwork
@{
    ViewBag.Title = "title";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/site.css">

<section id="ladda-upp" class="upload-section">
    <h2 class="section-title">Lägg till nytt konstverk</h2>
    <p class="section-intro">
        Detta är en visuell skiss för en framtida adminfunktion där konstnären kan
        ladda upp bild, ljudfil och textfil till varje verk.
    </p>

    <form class="upload-form"
          asp-controller="Create"
          asp-action="Index"
          method="post"
          enctype="multipart/form-data">

        <div>
            <label asp-for="Title">Titel på konstverk</label>
            <input asp-for="Title" placeholder="Exempel: Minne av ljus" />
        </div>

        <div>
            <label asp-for="Description">Beskrivning</label>
            <textarea asp-for="Description"></textarea>
        </div>

        <div>
            <label for="audioFile">Ljudfil</label>
            <input id="audioFile" name="audioFile" type="file" accept="audio/*" />
        </div>

        <div>
            <label for="textFile">Textfil</label>
            <input id="textFile" name="textFile" type="file" accept=".pdf,.doc,.docx,.txt" />
        </div>

        <button type="submit" class="btn">Spara konstverk</button>
    </form>
</section>